# Copie para .env e preencha os valores

# LLM Provider: "ollama" (local, grátis) ou "openai"
LLM_PROVIDER=ollama

# Ollama (modelo local — instale em https://ollama.com)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (opcional — só se LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Embedding model (HuggingFace, sem custo)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# RAG
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TEMPERATURE=0.2
